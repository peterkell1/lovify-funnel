# Copy to .env.local and fill in real values. Restart `npm run dev` after editing.

# ─── Supabase (same project as lovifymusic + lovify-admin) ───
NEXT_PUBLIC_SUPABASE_URL=https://auth.trylovify.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# Service role — used by /api/sessions, /api/answers, /api/payment-intent,
# /app/[slug] SSR loader. Never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=sb_service_xxx

# ─── Stripe ───
# Test keys for dev; live keys in Vercel prod env.
# Price IDs are NOT stored here — they live in funnels.plan_options JSONB
# (managed via lovify-admin) so marketing can swap plans without redeploy.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx

# ─── Meta Pixel ───
# Browser Pixel fbq() fires from the <MetaPixelBase /> component in layout.tsx.
# Per-funnel pixel override lives on funnels.meta_pixel_id; this is the fallback.
NEXT_PUBLIC_META_PIXEL_ID=1234567890
# Server-side Conversions API token (for /api/meta-capi route).
META_CAPI_TOKEN=EAA_xxx

# ─── Attribution cookie signing ───
# Middleware signs the lfa cookie with HS256 using this secret. Pick a
# random 32-byte hex string (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))").
# Rotating this invalidates all in-flight attribution cookies.
ATTRIBUTION_COOKIE_SECRET=replace_with_32_bytes_hex

# ─── Cache revalidation (admin → funnel) ───
# Shared secret between lovify-admin and /api/revalidate here. When an admin
# publishes/edits a funnel, the admin POSTs with header x-revalidate-secret
# to bust the unstable_cache entry for that slug.
FUNNEL_REVALIDATE_SECRET=replace_with_shared_secret

# ─── Auth + marketing URLs ───
# Post-purchase success page links users to auth.trylovify.com/set-password.
NEXT_PUBLIC_AUTH_URL=https://auth.trylovify.com
# Root of funnel.trylovify.com/ redirects here.
NEXT_PUBLIC_MARKETING_URL=https://trylovify.com

# ─── App Store / Play Store URLs (success page CTAs) ───
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/lovify
NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.lovify
